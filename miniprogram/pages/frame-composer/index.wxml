<!--pages/frame-composer/index.wxml-->
<view class="container">
  <!-- 顶部操作栏 -->
  <view class="header">
    <button class="btn-select" bindtap="chooseImage">
      <text class="icon">📷</text>
      选择照片
    </button>
    <button class="btn-type" bindtap="showTypePicker">
      <text class="icon">{{segmentTypes.find(t => t.key === segmentType)?.icon || '🎯'}}</text>
      {{segmentTypes.find(t => t.key === segmentType)?.name || '选择类型'}}
    </button>
    <button class="btn-frame" bindtap="showFramePicker">
      <text class="icon">🖼️</text>
      更换相框
    </button>
  </view>

  <!-- 主画布区域 -->
  <view class="canvas-area">
    <canvas 
      type="2d" 
      id="mainCanvas" 
      class="main-canvas"
      bindtouchstart="handleTouchStart"
      bindtouchmove="handleTouchMove"
      bindtouchend="handleTouchEnd"
    ></canvas>
    
    <!-- 加载提示 -->
    <view class="loading-mask" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{loadingText}}</text>
    </view>
    
    <!-- 初始引导 -->
    <view class="guide-mask" wx:if="{{!imagePath}}">
      <text class="guide-icon">📸</text>
      <text class="guide-text">点击上方按钮选择照片</text>
      <text class="guide-subtext">AI 将自动抠出主体，创造跃出相框效果</text>
    </view>
  </view>

  <!-- 底部控制栏 -->
  <view class="controls" wx:if="{{imagePath}}">
    <view class="control-group">
      <text class="control-label">缩放</text>
      <slider 
        min="0.5" 
        max="1.5" 
        step="0.1" 
        value="{{transform.scale}}"
        bindchange="onScaleChange"
        block-size="18"
      />
    </view>
    
    <view class="control-group">
      <text class="control-label">旋转</text>
      <slider 
        min="-30" 
        max="30" 
        step="1" 
        value="{{transform.rotate}}"
        bindchange="onRotateChange"
        block-size="18"
      />
    </view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="footer" wx:if="{{imagePath}}">
    <button class="btn-reset" bindtap="resetTransform">
      <text class="icon">🔄</text>
      重置
    </button>
    <button class="btn-save" bindtap="saveImage">
      <text class="icon">💾</text>
      保存到相册
    </button>
  </view>
</view>
