.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40rpx;
}

.hero {
  background: #ffffff;
  border-radius: 22px;
  box-shadow: 0 16px 40px rgba(47, 73, 55, 0.08);
  padding: 40rpx;
  text-align: center;
}

.eyebrow {
  display: inline-block;
  font-size: 12px;
  color: #4d6a53;
  background: #edf6ef;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1e2a22;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 16px;
  color: #6a786f;
  margin-bottom: 40rpx;
}

.tips {
  background: #f8fff8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
  text-align: left;
}

.tip-item {
  font-size: 14px;
  color: #4d6a53;
  margin: 8rpx 0;
}

.btn-start {
  background: #4d6a53;
  color: #fff;
  font-size: 18px;
  font-weight: 700;
  padding: 28rpx;
  border-radius: 14rpx;
  border: none;
}

.btn-start:active {
  opacity: 0.9;
}

.footer {
  margin-top: 40rpx;
  text-align: center;
}

.credit {
  font-size: 12px;
  color: #6a786f;
  margin-bottom: 8rpx;
}

.disclaimer {
  font-size: 12px;
  color: #9aa89f;
}
