<view class="container">
  <view class="card test-card">
    <view class="topbar">
      <view class="progress-text">第 {{currentQuestion + 1}} / {{questions.length}} 题</view>
      <view class="progress">
        <view class="progress-bar" style="width: {{progress}}%"></view>
      </view>
    </view>

    <view class="question-section">
      <view class="question-dim">{{getDimName(currentQuestionObj.dim)}}</view>
      <view class="question-text">{{currentQuestionObj.text}}</view>
    </view>

    <view class="options-section">
      <view 
        class="option-item {{selectedOption === index ? 'selected' : ''}}"
        wx:for="{{currentQuestionObj.options}}"
        wx:key="value"
        bindtap="selectOption"
        data-value="{{item.value}}"
        data-index="{{index}}"
      >
        <view class="option-label">{{item.label}}</view>
      </view>
    </view>

    <view class="action-section">
      <button 
        class="btn-next" 
        type="warn" 
        bindtap="nextQuestion"
        disabled="{{selectedOption === null}}"
      >
        {{currentQuestion === questions.length - 1 ? '提交' : '下一题'}}
      </button>
    </view>
  </view>
</view>
